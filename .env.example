# DCYFR dcyfr-ai Environment — Example
# Copy this file to .env and replace 1Password Vault/Item names with your own.
# Install 1Password CLI: bash scripts/setup-1password.sh
# Format: op://<Vault>/<Item>/<Field>

# ─── Secrets (1Password References) ────────────────────────────────────────
OPENAI_API_KEY="op://<YourVault>/OpenAI/api_key"

# ─── Provider Endpoints ───────────────────────────────────────────────────
MSTY_VIBE_PROXY_URL=
GITHUB_TOKEN=

# ─── Configuration ─────────────────────────────────────────────────────────
VECTOR_DB_PROVIDER=
VECTOR_DB_URL=
VECTOR_DB_INDEX=
LLM_PROVIDER=
OPENAI_API_VERSION=v4
ANTHROPIC_API_VERSION=v074
OPENAI_API_BASE=
LLM_MODEL=
LLM_EMBEDDING_MODEL=
MEMORY_CACHE_ENABLED=
MEMORY_CACHE_TTL=
MEMORY_CACHE_MAX_SIZE=
NODE_ENV=
DCYFR_AGENTS_VERSION=
