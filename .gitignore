# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Environment
# Never commit real .env files
.env
**/.env
.env.*
**/.env.*

# Keep safe templates/examples tracked
!.env.example
!**/.env.example

# .env.local contains plaintext secrets — NEVER commit
.env.local
.env.*.local
config.json
**/.archive/**
**/.private/**

# Dependencies
node_modules/
# package-lock.json is committed for reproducible builds
yarn.lock
pnpm-lock.yaml

# Test coverage
coverage/
.nyc_output/
*.lcov
.vitest/

# Build outputs
dist/
*.tsbuildinfo

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.dcyfr/telemetry.log
telemetry-output.jsonl

# Temporary files
*.tmp
temp/
tmp/

# Private directories
.dcyfr-workspace/
**/.private/**

# Changesets (don't ignore .changeset/*.md files - those should be committed)
**/.archive/**