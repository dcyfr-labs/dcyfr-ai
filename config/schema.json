        "pageLayout": {
          "type": "object",
          "properties": {
            "enabled": {
              "default": true,
              "type": "boolean"
            },
            "targetUsage": {
              "default": 0.9,
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "pagePattern": {
              "default": "src/app/**/page.tsx",
              "type": "string"
            },
            "exceptions": {
              "default": [
                "ArticleLayout",
                "ArchiveLayout",
                "ErrorLayout"
              ],
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "strictMode": {
              "default": true,
              "type": "boolean"
            }
          },
          "required": [
            "enabled",
            "targetUsage",
            "pagePattern",
            "exceptions",
            "strictMode"
          ],
          "additionalProperties": false
        },
        "testData": {
          "type": "object",
          "properties": {
            "enabled": {
              "default": true,
              "type": "boolean"
            },
            "testPattern": {
              "default": "**/*.{test,spec}.{ts,tsx,js,jsx}",
              "type": "string"
            },
            "sensitivePatterns": {
              "type": "object",
              "properties": {
                "apiKeys": {
                  "default": true,
                  "type": "boolean"
                },
                "passwords": {
                  "default": true,
                  "type": "boolean"
                },
                "secrets": {
                  "default": true,
                  "type": "boolean"
                },
                "tokens": {
                  "default": true,
                  "type": "boolean"
                },
                "emails": {
                  "default": true,
                  "type": "boolean"
                },
                "urls": {
                  "default": true,
                  "type": "boolean"
                }
              },
              "required": [
                "apiKeys",
                "passwords",
                "secrets",
                "tokens",
                "emails",
                "urls"
              ],
              "additionalProperties": false
            },
            "allowedPrefixes": {
              "default": [
                "MOCK_",
                "TEST_",
                "FAKE_",
                "FIXTURE_"
              ],
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "required": [
            "enabled",
            "testPattern",
            "allowedPrefixes"
          ],
          "additionalProperties": false
        }
      },
      "additionalProperties": false
