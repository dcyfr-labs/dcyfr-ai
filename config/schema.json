        "configFileName": {
          "default": ".mcp.json",
          "type": "string"
        },
        "healthCheckInterval": {
          "default": 60000,
          "type": "number",
          "exclusiveMinimum": 0
        },
        "healthMonitoring": {
          "default": false,
          "type": "boolean"
        }
