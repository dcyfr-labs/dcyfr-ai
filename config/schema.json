    "agents": {
      "default": {
        "designTokens": {
          "enabled": true,
          "tokenFile": "src/lib/design-tokens.ts",
          "compliance": 0.9,
          "autofix": false,
          "strictMode": true
        },
        "barrelExports": {
          "enabled": true,
          "barrelPaths": [
            "@/components",
            "@/lib",
            "@/utils"
          ],
          "allowRelativeWithin": false,
          "strictMode": true,
          "exceptions": [
            "src/app/**/layout.tsx",
            "src/app/**/page.tsx"
          ]
        },
        "pageLayout": {
          "enabled": true,
          "targetUsage": 0.9,
          "pagePattern": "src/app/**/page.tsx",
          "exceptions": [
            "ArticleLayout",
            "ArchiveLayout",
            "ErrorLayout"
          ],
          "strictMode": true
        },
        "testData": {
          "enabled": true,
          "testPattern": "**/*.{test,spec}.{ts,tsx,js,jsx}",
          "allowedPrefixes": [
            "MOCK_",
            "TEST_",
            "FAKE_",
            "FIXTURE_"
          ]
        }
