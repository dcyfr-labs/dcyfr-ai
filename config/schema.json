      "type": "object",
      "properties": {
        "enabled": {
          "default": true,
          "type": "boolean"
        },
        "primary": {
          "default": "claude",
          "type": "string"
        },
        "fallback": {
          "default": [
            "copilot",
            "github-models",
            "groq",
            "msty",
            "ollama"
          ],
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "timeout": {
          "default": 30000,
          "type": "number",
          "exclusiveMinimum": 0
        },
        "retries": {
          "default": 3,
          "type": "number",
          "minimum": 0
        },
        "providers": {
          "type": "object",
          "propertyNames": {
            "type": "string"
