{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "version": {
      "default": "1.0.0",
      "type": "string"
    },
    "projectName": {
      "type": "string"
    },
    "telemetry": {
      "default": {
        "enabled": true,
        "storage": "file",
        "storagePath": ".dcyfr/telemetry",
        "retentionDays": 30,
        "sampling": 1
      },
      "type": "object",
      "properties": {
        "enabled": {
          "default": true,
          "type": "boolean"
        },
        "storage": {
          "default": "file",
          "type": "string",
          "enum": [
            "memory",
            "file",
            "redis",
            "database"
          ]
        },
        "storagePath": {
          "default": ".dcyfr/telemetry",
          "type": "string"
        },
        "retentionDays": {
          "default": 30,
          "type": "number",
          "exclusiveMinimum": 0
        },
        "sampling": {
          "default": 1,
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      },
      "required": [
        "enabled",
        "storage",
        "storagePath",
        "retentionDays",
        "sampling"
