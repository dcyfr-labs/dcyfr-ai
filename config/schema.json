              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "allowRelativeWithin": {
              "default": false,
              "type": "boolean"
            },
            "strictMode": {
              "default": true,
              "type": "boolean"
            },
            "exceptions": {
              "default": [
                "src/app/**/layout.tsx",
                "src/app/**/page.tsx"
              ],
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "required": [
            "enabled",
            "barrelPaths",
            "allowRelativeWithin",
            "strictMode",
            "exceptions"
          ],
          "additionalProperties": false
