    "project": {
      "default": {
        "root": ".",
        "include": [
          "src/**/*.{ts,tsx,js,jsx}"
        ],
        "exclude": [
          "node_modules/**",
          "dist/**",
          "build/**",
          ".next/**"
        ]
      },
      "type": "object",
      "properties": {
        "root": {
          "default": ".",
          "type": "string"
        },
        "include": {
          "default": [
            "src/**/*.{ts,tsx,js,jsx}"
          ],
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "exclude": {
          "default": [
            "node_modules/**",
            "dist/**",
            "build/**",
            ".next/**"
