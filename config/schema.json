          "additionalProperties": {
            "type": "object",
            "properties": {
              "enabled": {
                "default": true,
                "type": "boolean"
              },
              "apiKey": {
                "type": "string"
              },
              "baseUrl": {
                "type": "string"
              },
              "model": {
                "type": "string"
              },
              "maxTokens": {
                "type": "number",
                "exclusiveMinimum": 0
              }
            },
            "required": [
              "enabled"
            ],
            "additionalProperties": false
          }
        }
      },
      "required": [
        "enabled",
        "primary",
        "fallback",
        "timeout",
        "retries"
      ],
      "additionalProperties": false
    },
    "validation": {
      "default": {
        "enabled": true,
        "parallel": true,
        "failFast": false,
        "gates": []
