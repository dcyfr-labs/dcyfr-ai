                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "typography": {
                  "default": [
                    "TYPOGRAPHY.H1",
                    "TYPOGRAPHY.H2",
                    "TYPOGRAPHY.BODY"
                  ],
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "colors": {
                  "default": [
                    "SEMANTIC_COLORS.primary",
                    "SEMANTIC_COLORS.success"
                  ],
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              },
              "required": [
                "spacing",
                "typography",
                "colors"
              ],
              "additionalProperties": false
            }
          },
          "required": [
            "enabled",
            "tokenFile",
            "compliance",
            "autofix",
            "strictMode"
